{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "USTBL",
  "version": "0.1.0",
  "identifier": "USTBL",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": " ",
        "url": "/",
        "width": 800,
        "height": 550,
        "minWidth": 800,
        "minHeight": 550,
        "center": true,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": false
      },
      {
        "label": "game_error",
        "create": false,
        "title": "Game Error",
        "url": "/standalone/game-error",
        "width": 800,
        "height": 550,
        "minWidth": 640,
        "minHeight": 440,
        "center": true,
        "dragDropEnabled": false
      },
      {
        "label": "game_log",
        "create": false,
        "title": "Game Log",
        "url": "/standalone/game-log",
        "width": 800,
        "height": 550,
        "minWidth": 640,
        "minHeight": 440,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "**/.*/**",
          "**/.*/**/.*/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "Game",
    "icon": [
      "assets/icons/icon.ico"
    ],
    "licenseFile": "../LICENSE",
    "license": "GPLv3",
    "windows": {
      "nsis": {
        "installerIcon": "assets/icons/icon.ico",
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese"
        ]
      }
    },
    "resources": [
      "assets/skins/*",
      "assets/game/*",
      "assets/icons/icon.ico",
      "assets/icons/variants/square.png",
      "assets/db/*"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "sjmcl"
        ]
      }
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
